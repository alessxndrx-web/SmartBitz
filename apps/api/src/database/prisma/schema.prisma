generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  ruc              String
  businessType     String   @default("BARBERSHOP")
  subscriptionPlan String   @default("BASIC")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users          User[]
  memberships    TenantMembership[]
  customers      Customer[]
  invoices       Invoice[]
  inventoryItems InventoryItem[]
  categories     Category[]
  movements      InventoryMovement[]
  suppliers      Supplier[]
  purchases      Purchase[]
  roles          Role[]
  permissions    Permission[]
  auditLogs      AuditLog[]
  supportTickets SupportTicket[]
  files          File[]
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  fullName  String
  email     String   @unique
  password  String
  role      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships TenantMembership[]
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  fullName  String
  phone     String?
  email     String?
  address   String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([tenantId, createdAt])
}

model Invoice {
  id         String    @id @default(cuid())
  tenantId   String
  number     String
  customerId String?
  subtotal   Float     @default(0)
  tax        Float     @default(0)
  total      Float     @default(0)
  status     String    @default("draft")
  issueDate  DateTime  @default(now())
  dueDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    InvoiceItem[]
  payments Payment[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  discount    Float    @default(0)
  taxRate     Float    @default(0)
  total       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
}

model InventoryItem {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  sku         String?
  description String?
  categoryId  String?
  quantity    Float    @default(0)
  minStock    Float    @default(0)
  unitCost    Float    @default(0)
  salePrice   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category      Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  movements     InventoryMovement[]
  purchaseItems PurchaseItem[]

  @@index([tenantId, isActive])
  @@index([tenantId, createdAt])
}

model Category {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  InventoryItem[]
}

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  ruc       String?
  phone     String?
  email     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases Purchase[]
}

model Purchase {
  id           String    @id @default(cuid())
  tenantId     String
  supplierId   String
  number       String
  subtotal     Float     @default(0)
  tax          Float     @default(0)
  total        Float     @default(0)
  status       String    @default("pending") // pending, received, cancelled
  purchaseDate DateTime  @default(now())
  receivedAt   DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items    PurchaseItem[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  itemId     String
  quantity   Float
  unitCost   Float
  discount   Float    @default(0)
  taxRate    Float    @default(0)
  total      Float    @default(0)
  received   Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  purchase Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item     InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model InventoryMovement {
  id        String   @id @default(cuid())
  tenantId  String
  itemId    String
  type      String   @default("adjustment") // in, out, adjustment, sale, purchase
  quantity  Float
  reference String?
  notes     String?
  createdAt DateTime @default(now())

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@index([tenantId, name])
}

model Permission {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  module      String
  action      String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@index([tenantId, module, action])
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  module     String
  action     String
  entityId   String?
  entityType String?
  oldValues  String? // JSON string of previous values
  newValues  String? // JSON string of new values
  ipAddress  String?
  userAgent  String?
  notes      String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, module, createdAt])
  @@index([tenantId, userId, createdAt])
  @@index([tenantId, entityType, entityId])
}

model SupportTicket {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String?
  subject     String
  description String
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  category    String? // BILLING, TECHNICAL, FEATURE, BUG, OTHER
  assignedTo  String? // Internal staff ID who handles the ticket
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model File {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String?
  filename     String
  originalName String
  mimeType     String
  size         Float // in bytes
  path         String // storage path
  category     String? // DOCUMENT, IMAGE, VIDEO, OTHER
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@index([tenantId, createdAt])
}

model TenantMembership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId, createdAt])
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  amount      Float
  method      String // cash, card, transfer, etc.
  status      String   @default("pending") // pending, completed, failed
  paymentDate DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
}
