{
  "name": "@smartbitz/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:isolation": "jest test/tenant-isolation.e2e-spec.ts --verbose",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx src/database/prisma/seeds/seed.ts",
    "worker": "tsx src/worker.ts",
    "infra:up": "docker compose -f ../../docker-compose.yml up -d postgres redis",
    "infra:down": "docker compose -f ../../docker-compose.yml down",
    "infra:logs": "docker compose -f ../../docker-compose.yml logs -f postgres redis",
    "test:e2e:critical": "jest --config ./test/jest-e2e.json --runInBand test/http/auth.http.e2e-spec.ts test/http/guards-and-platform-admin.http.e2e-spec.ts test/http/tenant-modules-access.http.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/throttler": "^5.2.0",
    "@prisma/client": "^5.20.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "helmet": "^8.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prisma": "^5.20.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0"
  },
  "prisma": {
    "schema": "src/database/prisma/schema.prisma"
  }
}
